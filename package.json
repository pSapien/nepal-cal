{
  "name": "@psapien/nepal-cal",
  "version": "0.0.4",
  "description": "A command line utility to display a formatted Nepali calendar in the terminal. Think 'cal' but for Nepali calendar",
  "main": "dist/cli.js",
  "bin": {
    "ncal": "bin/ncal.js"
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc",
    "start": "node bin/ncal.js",
    "dev": "tsc --watch",
    "start:dev": "node --watch bin/ncal.js",
    "publish": "npm publish --access public"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "nepali",
    "calendar",
    "cli",
    "cal",
    "terminal",
    "BS",
    "bikram sambat",
    "date"
  ],
  "author": "Prateek Thapa",
  "license": "ISC",
  "dependencies": {
    "nepali-date-converter": "3.4.0"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3"
  }
}